{
  "name": "codex-switcher",
  "displayName": "Codex Session Switcher",
  "description": "Switch Codex auth.json between multiple local sessions.",
  "version": "0.0.2",
  "publisher": "luccasoliva",
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/luccasoliva/codex-session-switcher.git"
  },
  "bugs": {
    "url": "https://github.com/luccasoliva/codex-session-switcher/issues"
  },
  "homepage": "https://github.com/luccasoliva/codex-session-switcher#readme",
  "keywords": [
    "codex",
    "openai",
    "session",
    "switcher",
    "auth",
    "vscode"
  ],
  "galleryBanner": {
    "color": "#111827",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:codexSessionsView",
    "onCommand:codexSessions.add",
    "onCommand:codexSessions.switch",
    "onCommand:codexSessions.showActive",
    "onCommand:codexSessions.openStorage",
    "onCommand:codexSessions.reloadWindow",
    "onCommand:codexSessions.remove",
    "onCommand:codexSessions.refreshView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codexSessionsContainer",
          "title": "Codex Switcher",
          "icon": "media/codex-switcher.svg"
        }
      ]
    },
    "views": {
      "codexSessionsContainer": [
        {
          "type": "webview",
          "id": "codexSessionsView",
          "name": "Sessions"
        }
      ]
    },
    "commands": [
      {
        "command": "codexSessions.add",
        "title": "Codex Sessions: Add Session",
        "icon": "$(add)"
      },
      {
        "command": "codexSessions.switch",
        "title": "Codex Sessions: Switch Session",
        "icon": "$(account)"
      },
      {
        "command": "codexSessions.showActive",
        "title": "Codex Sessions: Show Active Session",
        "icon": "$(eye)"
      },
      {
        "command": "codexSessions.openStorage",
        "title": "Codex Sessions: Open Storage Folder",
        "icon": "$(folder-opened)"
      },
      {
        "command": "codexSessions.reloadWindow",
        "title": "Codex Sessions: Reload VS Code Window",
        "icon": "$(refresh)"
      },
      {
        "command": "codexSessions.remove",
        "title": "Codex Sessions: Remove Saved Session",
        "icon": "$(trash)"
      },
      {
        "command": "codexSessions.refreshView",
        "title": "Codex Sessions: Refresh View",
        "icon": "$(refresh)"
      }
    ],
    "configuration": {
      "title": "Codex Session Switcher",
      "properties": {
        "codexSessionSwitcher.codexHome": {
          "type": "string",
          "default": "",
          "description": "Codex home path. Defaults to ~/.codex."
        },
        "codexSessionSwitcher.switcherHome": {
          "type": "string",
          "default": "",
          "description": "Switcher storage path. Defaults to ~/.codex-switcher."
        },
        "codexSessionSwitcher.promptReloadAfterSwitch": {
          "type": "boolean",
          "default": true,
          "description": "Ask to reload VS Code after switching Codex session."
        },
        "codexSessionSwitcher.autoUseNewSession": {
          "type": "boolean",
          "default": false,
          "description": "Automatically activate newly added Codex session after login."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.5"
  }
}